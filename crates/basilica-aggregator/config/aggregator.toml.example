# Basilica GPU Price Aggregator Configuration

[server]
host = "0.0.0.0"
port = 8080

[cache]
# Cache TTL in seconds
ttl_seconds = 45

[database]
path = "aggregator.db"

# Provider configurations
[providers.datacrunch]
enabled = true
client_id = "${DATACRUNCH_CLIENT_ID}"
client_secret = "${DATACRUNCH_CLIENT_SECRET}"
api_base_url = "https://api.datacrunch.io/v1"
# Minimum seconds between API calls to the same provider
cooldown_seconds = 30
# Request timeout in seconds
timeout_seconds = 10

[providers.hyperstack]
enabled = false
# client_id = "${HYPERSTACK_CLIENT_ID}"
# client_secret = "${HYPERSTACK_CLIENT_SECRET}"
# api_base_url = "https://api.hyperstack.cloud/v1"
cooldown_seconds = 30
timeout_seconds = 10

[providers.lambda]
enabled = false
# client_id = "${LAMBDA_CLIENT_ID}"
# client_secret = "${LAMBDA_CLIENT_SECRET}"
# api_base_url = "https://api.lambdalabs.com/v1"
cooldown_seconds = 30
timeout_seconds = 10
