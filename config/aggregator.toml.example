[server]
host = "0.0.0.0"
port = 8080

[cache]
ttl_seconds = 45

[providers.datacrunch]
# Optional: To enable DataCrunch provider, uncomment and configure:
# client_id = "your-datacrunch-client-id"
# client_secret = "your-datacrunch-client-secret"
# api_base_url = "https://api.datacrunch.io/v1"
# Or override with environment variables:
#   export AGGREGATOR__PROVIDERS__DATACRUNCH__CLIENT_ID="your-client-id"
#   export AGGREGATOR__PROVIDERS__DATACRUNCH__CLIENT_SECRET="your-client-secret"
#   export AGGREGATOR__PROVIDERS__DATACRUNCH__API_BASE_URL="https://api.datacrunch.io/v1"
cooldown_seconds = 30
timeout_seconds = 10

[providers.hyperstack]
# Optional: To enable Hyperstack provider, uncomment and configure:
# api_key = "your-hyperstack-api-key"
# api_base_url = "https://infrahub-api.nexgencloud.com/v1"
# Or override with environment variable:
#   export AGGREGATOR__PROVIDERS__HYPERSTACK__API_KEY="your-api-key"
#   export AGGREGATOR__PROVIDERS__HYPERSTACK__API_BASE_URL="https://infrahub-api.nexgencloud.com/v1"
cooldown_seconds = 30
timeout_seconds = 10

[providers.lambda]
# Optional: To enable Lambda provider, uncomment and configure:
# api_key = "your-lambda-api-key"
# api_base_url = "https://cloud.lambdalabs.com/api/v1"
# Or override with environment variable:
#   export AGGREGATOR__PROVIDERS__LAMBDA__API_KEY="your-api-key"
#   export AGGREGATOR__PROVIDERS__LAMBDA__API_BASE_URL="https://cloud.lambdalabs.com/api/v1"
cooldown_seconds = 30
timeout_seconds = 10

[providers.hydrahost]
# Optional: To enable HydraHost provider, uncomment and configure:
# api_key = "your-hydrahost-api-key"
# api_base_url = "https://api.brokkr.prod.hydra.host"
# Or override with environment variable:
#   export AGGREGATOR__PROVIDERS__HYDRAHOST__API_KEY="your-api-key"
#   export AGGREGATOR__PROVIDERS__HYDRAHOST__API_BASE_URL="https://api.brokkr.prod.hydra.host"
cooldown_seconds = 30
timeout_seconds = 10

[database]
path = "aggregator.db"
