# Basilica API Configuration Example
# Copy this file to basilica-api.toml and customize for your environment
#
# Environment Variable Override Convention:
# - Use double underscores (__) to separate nested fields
# - Prefix all variables with BASILICA_API_
# - Examples:
#   BASILICA_API_SERVER__BIND_ADDRESS=0.0.0.0:9000
#   BASILICA_API_DATABASE__URL=postgres://user:pass@host/db
#   BASILICA_API_DATABASE__MAX_CONNECTIONS=10
#   BASILICA_API_BITTENSOR__NETUID=387

[server]
bind_address = "0.0.0.0:8000"
request_timeout = 60

[bittensor]
# Network: "finney" for mainnet (Subnet 39) or "test" for testnet (Subnet 387)
network = "test"
netuid = 387
chain_endpoint = "wss://test.finney.opentensor.ai:443"
# REQUIRED: Specify the validator hotkey (SS58 address) to connect to
validator_hotkey = "5FxJav..."  # Replace with actual validator hotkey
discovery_interval = 30

[database]
# Database URL - PostgreSQL for both development and production
# Example: "postgres://user:password@localhost:5432/basilica"
# For local development with docker-compose: "postgres://basilica:dev@localhost:5432/basilica"
url = "postgres://basilica:dev@localhost:5432/basilica"
max_connections = 5

[pricing]
# Marketplace pricing markup percentages
# Community cloud: markup applied to community-provided GPU rentals
community_markup_percent = 10.0
# Secure cloud: markup applied to datacenter provider GPU rentals
secure_cloud_markup_percent = 15.0

# GPU Aggregator configuration (Secure Cloud)
# Uncomment to enable secure cloud GPU offerings from external providers
# [aggregator]
# ttl_seconds = 45
#
# [aggregator.providers]
# # DataCrunch (OAuth authentication)
# datacrunch = { client_id = "your_client_id", client_secret = "your_client_secret" }
# # Hyperstack (API key authentication)
# hyperstack = { api_key = "your_api_key" }
# # Lambda (API key authentication)
# lambda = { api_key = "your_api_key" }
# # HydraHost (API key authentication)
# hydrahost = { api_key = "your_api_key" }
