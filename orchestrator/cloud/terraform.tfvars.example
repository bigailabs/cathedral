# AWS Configuration
aws_region   = "us-east-2"
project_name = "basilica-k3s"

# SSH Key Configuration
# Option 1: Use existing AWS key pair
# ssh_key_name = "my-existing-key"

# Option 2: Generate new SSH key (leave ssh_key_name empty)
ssh_key_name         = ""
ssh_public_key_path  = "~/.ssh/id_rsa.pub"

# SSH Access Control
# CIDR blocks allowed to SSH into K3s nodes
# Default allows all IPs - restrict this in production
allowed_ssh_cidr_blocks = ["0.0.0.0/0"]

# Example: Restrict to specific IPs
# allowed_ssh_cidr_blocks = [
#   "203.0.113.10/32",  # Your office IP
#   "198.51.100.0/24",  # Your VPN subnet
# ]

# K3s Server Configuration (Control Plane)
# Number of server nodes - must be odd for etcd quorum (1, 3, 5, etc.)
# Recommended: 3 for HA production, 1 for dev/test
k3s_server_count            = 3
k3s_server_instance_type    = "t3.xlarge"
k3s_server_root_volume_size = 100

# K3s Agent Configuration (Worker Nodes)
k3s_agent_instance_type    = "t3.medium"
k3s_agent_count            = 2
k3s_agent_root_volume_size = 100

# Network Configuration
enable_public_ips = true

# Ubuntu AMI Configuration
ubuntu_ami_owner = "099720109477"
ubuntu_version   = "24.04"

# =============================================================================
# VPC PEERING CONFIGURATION (for ECS API connectivity to K3s cluster)
# =============================================================================
# Enable VPC peering between K3s cluster and ECS services VPC
# This allows the basilica-api service running in ECS to connect to K3s API
#
# Steps to configure VPC peering:
# 1. Deploy scripts/cloud/ ECS infrastructure first
# 2. Get outputs: terraform output -state=../../scripts/cloud/terraform.tfstate
# 3. Copy vpc_id, vpc_cidr, private_route_table_id values below
# 4. Deploy this K3s infrastructure
# 5. VPC peering will be established automatically
#
# Leave empty to disable VPC peering (API will use kubeconfig with public endpoint)

# ECS VPC ID (from scripts/cloud/ terraform output vpc_id)
peer_vpc_id = ""
# Example: peer_vpc_id = "vpc-0123456789abcdef0"

# ECS VPC CIDR block (from scripts/cloud/ terraform output vpc_cidr)
peer_vpc_cidr = ""
# Example dev:  peer_vpc_cidr = "10.0.0.0/16"
# Example prod: peer_vpc_cidr = "10.1.0.0/16"

# ECS private route table ID (from scripts/cloud/ terraform output private_route_table_id)
peer_route_table_id = ""
# Example: peer_route_table_id = "rtb-0123456789abcdef0"

# =============================================================================
# DEPLOYMENT PUBLIC IP (advanced)
# =============================================================================
# Public IP/DNS for user deployments
# Defaults to primary K3s server IP, update after Envoy LB is provisioned
deployment_public_ip = ""
# Example: deployment_public_ip = "basilica-envoy-lb-123456.us-east-2.elb.amazonaws.com"
