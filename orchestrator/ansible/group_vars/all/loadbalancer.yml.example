---
# Load Balancer Configuration

# Basilica uses default K3s service load balancing
# Future: Uncomment to use advanced load balancers

# MetalLB configuration (optional)
# metal_lb_mode: layer2
# metal_lb_type: native
# metal_lb_ip_range: 192.168.30.80-192.168.30.90
# metal_lb_controller_tag_version: v0.14.8
# metal_lb_speaker_tag_version: v0.14.8

# MetalLB BGP configuration (optional)
# metal_lb_mode: bgp
# metal_lb_bgp_my_asn: "64513"
# metal_lb_bgp_peer_asn: "64512"
# metal_lb_bgp_peer_address: 192.168.30.1

# kube-vip configuration (alternative to MetalLB)
# Uncomment to use kube-vip instead of MetalLB
# kube_vip_lb_ip_range: 192.168.30.80-192.168.30.90
# kube_vip_arp: true
# kube_vip_bgp: false
# kube_vip_tag_version: v0.8.2

# VIP for API server (HA clusters)
# apiserver_endpoint: 192.168.30.222
