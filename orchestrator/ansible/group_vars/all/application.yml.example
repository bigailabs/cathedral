# Global defaults for Basilica K3s + E2E setup

# K3s
k3s_channel: stable               # e.g., stable, v1.29
k3s_disable_traefik: true         # disable built-in Traefik (we use Envoy/Gateway)
k3s_server_exec_args: >-
  --disable traefik
  --write-kubeconfig-mode 644
  --tls-san {{ first_master_ip | default(ansible_host) }}

# Agents can add custom args (e.g., taints/labels)
k3s_agent_exec_args: >-
  --node-label basilica.ai/workloads-only=true

# E2E readiness
tenant_namespace: basilica-system

# Image refs (override with your registry)
operator_image: ghcr.io/one-covenant/basilica-operator:latest

# Image pull policy (Always, IfNotPresent, Never)
# Use IfNotPresent for dev with local images, Always for production
operator_image_pull_policy: IfNotPresent

# User Deployment config
deployment_public_ip: "localhost"
deployment_public_port: "8080"

# Toggles
install_envoy_forward_proxy: true   # apply forward proxy (k8s/networking/envoy/*)
install_gateway_api: true           # apply Gateway API bits (k8s/networking/gateway-api/*)

# CRD generation (DEPRECATED - CRDs are now pre-generated and version-controlled)
# CRDs are located at: k8s/crds/basilica-crds.yaml
# To regenerate: cargo run -p basilica-operator --bin crdgen > k8s/crds/basilica-crds.yaml
generate_crds: false
crdgen_cmd: cargo run -p basilica-operator --bin crdgen
crds_output: k8s/crds/basilica-crds.yaml

# Path to repo root on the control machine (auto-detected in playbook)
repo_root: ""

# Use templates for operator manifests instead of in-place edits
use_templates: true

# Run smoke tests after deployment
run_smoke_probe: true

# Long-lived Envoy HTTP forward proxy port-forward
envoy_forward:
  enabled: false
  namespace: basilica-system
  resource_kind: svc
  resource_name: basilica-envoy
  local_port: 8080
  remote_port: 8080
  bind_address: 127.0.0.1

# Optional Envoy admin (9901)
envoy_admin_forward:
  enabled: false
  namespace: basilica-system
  resource_kind: svc
  resource_name: basilica-envoy
  local_port: 9901
  remote_port: 9901
  bind_address: 127.0.0.1

