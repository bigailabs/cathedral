---
# CNI Configuration

# Basilica uses Flannel (K3s default) by default
# Future: Uncomment to use alternative CNI

# Calico configuration (uncomment to use)
# calico_iface: eth0
# calico_tag: v3.28.0
# calico_ebpf: false
# calico_encapsulation: VXLANCrossSubnet
# cluster_cidr: 10.52.0.0/16

# Cilium configuration (uncomment to use)
# cilium_iface: eth0
# cilium_tag: v1.16.0
# cilium_mode: native
# cilium_hubble: true
# cilium_bgp: false
# cluster_cidr: 10.52.0.0/16

# BGP configuration (for Cilium BGP)
# cilium_bgp_my_asn: "64513"
# cilium_bgp_peer_asn: "64512"
# cilium_bgp_neighbors:
#   - peer_address: 192.168.30.1
#     peer_asn: 64512
# cilium_bgp_lb_cidr: 192.168.31.0/24
