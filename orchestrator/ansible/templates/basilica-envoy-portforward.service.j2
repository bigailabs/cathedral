[Unit]
Description=Basilica Envoy HTTP kubectl port-forward
After=network-online.target k3s.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/kubectl -n {{ envoy_forward.namespace }} port-forward {{ envoy_forward.resource_kind }}/{{ envoy_forward.resource_name }} {{ envoy_forward.local_port }}:{{ envoy_forward.remote_port }} --address {{ envoy_forward.bind_address }}
Environment=KUBECONFIG=/etc/rancher/k3s/k3s.yaml
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

