apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ issuer_name | default('letsencrypt-staging') }}
spec:
  acme:
    email: {{ acme_email | quote }}
    server: {{ acme_server | default('https://acme-staging-v02.api.letsencrypt.org/directory') | quote }}
    privateKeySecretRef:
      name: {{ issuer_name | default('letsencrypt-staging') }}
    solvers:
    - http01:
        ingress:
          class: nginx

