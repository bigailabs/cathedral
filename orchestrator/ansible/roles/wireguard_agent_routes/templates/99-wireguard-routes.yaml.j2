# WireGuard routes for K3s agent
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
#
# Remote GPU nodes join the K3s cluster via WireGuard VPN with IPs from
# 10.200.0.0/16. This agent routes traffic to that network through the
# K3s server in its subnet which has WireGuard interface.
#
# Agent: {{ inventory_hostname }}
# Subnet: {{ agent_subnet }}
# Gateway: {{ agent_gateway }} ({{ agent_gateway_server }})

network:
  version: 2
  ethernets:
    {{ primary_interface.stdout }}:
      routes:
        - to: {{ wireguard_network }}
          via: {{ agent_gateway }}
