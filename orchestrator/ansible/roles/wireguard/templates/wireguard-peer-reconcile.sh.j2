#!/bin/bash
# WireGuard Peer Reconciliation Script
# Ensures GPU node peers have their pod CIDRs in AllowedIPs
# Deployed by Ansible - Do not edit manually
#
# This script addresses the chicken-and-egg problem:
# - GPU nodes register with WireGuard before joining K3s
# - Pod CIDRs are assigned when the node joins K3s
# - This reconciler adds pod CIDRs to AllowedIPs after node joins
#
# NOTE: Flannel VXLAN reconciliation (routes, FDB, neighbors) is handled
# separately by the K8s CronJob (wireguard-reconcile) to maintain single
# responsibility and avoid duplicate logic.
#
# Scalability: Designed to handle 100+ GPU nodes efficiently
# - Single kubectl call to fetch all node data
# - O(n) processing with minimal syscalls per node
# - Idempotent operations (check before modify)
# - Flock-based locking prevents concurrent execution

set -euo pipefail

readonly INTERFACE="{{ wireguard_interface }}"
readonly KUBECONFIG="${KUBECONFIG:-/etc/rancher/k3s/k3s.yaml}"
readonly LOG_TAG="wireguard-reconcile"
readonly MAX_NODES="${MAX_GPU_NODES:-500}"
readonly LOCK_FILE="/var/run/wireguard-reconcile.lock"
readonly LOCK_TIMEOUT="${LOCK_TIMEOUT:-60}"

# Cached node data (populated once per run)
CACHED_NODE_JSON=""

log() {
    logger -t "$LOG_TAG" "$1"
    echo "$(date -Iseconds) $1"
}

acquire_lock() {
    exec 200>"$LOCK_FILE"
    if ! flock -w "$LOCK_TIMEOUT" 200; then
        log "ERROR: Failed to acquire lock after ${LOCK_TIMEOUT}s, another instance running"
        exit 1
    fi
    trap 'flock -u 200' EXIT
}

# Fetch and cache node data (single kubectl call per run)
fetch_node_data() {
    if [ -z "$CACHED_NODE_JSON" ]; then
        CACHED_NODE_JSON=$(kubectl --kubeconfig="$KUBECONFIG" get nodes -o json 2>/dev/null) || {
            log "Failed to fetch node data from K8s API"
            return 1
        }
    fi
    echo "$CACHED_NODE_JSON"
}

# Get WireGuard IP to pod CIDR mapping from cached node data
get_node_cidrs() {
    local node_json
    node_json=$(fetch_node_data) || return 1

    echo "$node_json" | jq -r '.items[] |
        select(.metadata.labels["basilica.ai/wireguard"] == "true") |
        select(.spec.podCIDR != null) |
        "\(.status.addresses[] | select(.type == "InternalIP") | .address) \(.spec.podCIDR)"' 2>/dev/null || true
}

# Check if a CIDR is already in AllowedIPs
# AllowedIPs can be space-separated (wg show allowed-ips) or comma-separated (wg show dump)
cidr_in_allowed() {
    local allowed_ips="$1"
    local cidr="$2"
    echo "$allowed_ips" | tr ', ' '\n' | grep -qF "$cidr"
}

# Find public key for a WireGuard IP
find_pubkey_by_ip() {
    local target_ip="$1"
    wg show "$INTERFACE" dump 2>/dev/null | tail -n +2 | while read -r pubkey _ _ allowed_ips _; do
        if echo "$allowed_ips" | tr ',' '\n' | grep -qF "${target_ip}/32"; then
            echo "$pubkey"
            return
        fi
    done
}

reconcile_peers() {
    log "Starting WireGuard AllowedIPs reconciliation"
    local changes=0

    # Get GPU node WireGuard IPs and their pod CIDRs
    local node_data
    node_data=$(get_node_cidrs)

    if [ -z "$node_data" ]; then
        log "No GPU nodes with WireGuard labels and pod CIDRs found"
        return 0
    fi

    # Scalability check: warn if too many nodes
    local node_count
    node_count=$(echo "$node_data" | wc -l)
    if [ "$node_count" -gt "$MAX_NODES" ]; then
        log "WARNING: $node_count GPU nodes exceeds limit ($MAX_NODES). Consider increasing MAX_GPU_NODES."
    fi
    log "Processing $node_count GPU nodes"

    while IFS= read -r line; do
        [ -z "$line" ] && continue

        local wg_ip pod_cidr
        wg_ip=$(echo "$line" | awk '{print $1}')
        pod_cidr=$(echo "$line" | awk '{print $2}')

        [ -z "$wg_ip" ] || [ -z "$pod_cidr" ] && continue

        # Find the public key for this WireGuard IP
        local pubkey
        pubkey=$(find_pubkey_by_ip "$wg_ip")

        if [ -z "$pubkey" ]; then
            log "  No WireGuard peer found for IP $wg_ip (node may not be registered)"
            continue
        fi

        # Get current AllowedIPs for this peer (all fields after pubkey)
        local current_allowed
        current_allowed=$(wg show "$INTERFACE" allowed-ips 2>/dev/null | grep "^$pubkey" | awk '{$1=""; print substr($0,2)}')

        if [ -z "$current_allowed" ]; then
            log "  Cannot get AllowedIPs for peer $pubkey"
            continue
        fi

        # Check if pod CIDR is already in AllowedIPs
        if cidr_in_allowed "$current_allowed" "$pod_cidr"; then
            continue
        fi

        # Add pod CIDR to AllowedIPs (convert space-separated to comma-separated for wg set)
        local current_csv
        current_csv=$(echo "$current_allowed" | tr ' ' ',')
        local new_allowed="${current_csv},${pod_cidr}"
        log "  Adding pod CIDR $pod_cidr to peer ${pubkey:0:8}... (WG IP: $wg_ip)"

        if wg set "$INTERFACE" peer "$pubkey" allowed-ips "$new_allowed" 2>/dev/null; then
            changes=$((changes + 1))
            log "  Successfully updated peer ${pubkey:0:8}..."
        else
            log "  ERROR: Failed to update peer ${pubkey:0:8}..."
        fi
    done <<< "$node_data"

    if [ $changes -gt 0 ]; then
        log "Reconciliation complete: $changes peers updated"
    else
        log "Reconciliation complete: no changes needed"
    fi
}

main() {
    acquire_lock

    if [ ! -f "$KUBECONFIG" ]; then
        log "Kubeconfig not found at $KUBECONFIG, skipping reconciliation"
        exit 0
    fi

    if ! command -v wg &> /dev/null; then
        log "WireGuard tools not installed"
        exit 1
    fi

    if ! wg show "$INTERFACE" &> /dev/null; then
        log "WireGuard interface $INTERFACE not available"
        exit 1
    fi

    reconcile_peers
}

main "$@"
