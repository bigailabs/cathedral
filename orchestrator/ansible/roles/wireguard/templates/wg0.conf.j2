# WireGuard configuration for {{ inventory_hostname }}
# Generated by Ansible - DO NOT EDIT MANUALLY
# Peers are added dynamically via Basilica API

[Interface]
# Server IP on WireGuard network
Address = {{ wireguard_server_ip }}/16

# UDP port for WireGuard
ListenPort = {{ wireguard_port }}

# Private key (generated on this server)
PrivateKey = {{ wireguard_private_key }}

# Disable automatic route management - routes are handled by Flannel
# Pod CIDRs should route via flannel.1, not wg0
Table = off

# Do not save config - peers are managed by reconciliation script
SaveConfig = false

# MTU optimized for WireGuard over internet (1500 - 80 overhead = 1420)
MTU = {{ wireguard_mtu | default(1420) }}

# Note: Peers (GPU nodes) are added dynamically when they register
# via the Basilica API using: wg set wg0 peer <pubkey> allowed-ips <ip>/32
