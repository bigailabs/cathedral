# ===================================================================
# Ansible Configuration Files
# ===================================================================

# Vault password file (NEVER COMMIT!)
.vault_password
*.vault_password
.vault_pass

# Ansible retry files
*.retry

# Ansible facts cache
.ansible_facts/
.facts_cache/

# Ansible roles downloaded from Galaxy
roles/external/

# ===================================================================
# Inventory Files (Keep Examples)
# ===================================================================

# Production inventory files (keep example.ini)
inventories/production.ini
inventories/staging.ini
inventories/prod.ini
inventories/*.ini
!inventories/example.ini
!inventories/*.ini.example

# Main inventory file (telemetry pattern)
inventory
!inventory.example

# ===================================================================
# Variable Files (Keep Examples)
# ===================================================================

# Vault files with secrets (keep .example files)
group_vars/all/vault.yml
group_vars/*/vault.yml
host_vars/*/vault.yml
**/vault.yml
!**/vault.yml.example
group_vars/**/*.yml
!group_vars/**/*.yml.example
group_vars/all/*.yml
!group_vars/all/*.example

# Group-specific variable files (keep examples)
group_vars/*.yml
!group_vars/*.yml.example
!group_vars/all.yml

# Host-specific variables with production data (keep examples)
host_vars/*
host_vars/*.yml
!host_vars/*.yml.example

# Kubeconfig files
*.kubeconfig
*kubeconfig*
k3s.yaml
k3s-config.yaml
build/k3s.yaml
~/.kube/k3s-*
!playbooks/04-maintain/kubeconfig.yml

# SSH keys and certificates
*.pem
*.key
!*.key.example
*.pub
id_rsa*
id_ed25519*

# Cloud credentials
*credentials*
!*credentials*.example
*secret*
!*secret*.example
.env
.env.*
!.env.example

# R2/S3 credentials
r2-credentials.yml
group_vars/all/r2.yml
!group_vars/all/r2.yml.example

# Terraform state (if mixed with Ansible)
*.tfstate
*.tfstate.*
.terraform/

# Logs
*.log
logs/

# Temporary files
*.tmp
*.bak
*~
.DS_Store

# Python bytecode (if using Ansible with Python modules)
*.pyc
__pycache__/
.pytest_cache/

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Output directories
output/
downloads/
fetched/

ansible/playbooks/archived/
