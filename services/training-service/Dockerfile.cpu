# CPU-only image for local testing (no vLLM)
FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install CPU-only dependencies (skip vllm, ray)
COPY pyproject.toml .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir torch transformers peft accelerate safetensors tokenizers \
    boto3 fastapi uvicorn pydantic structlog httpx

# Copy source code
COPY src/ src/
COPY tests/ tests/

RUN mkdir -p /models /checkpoints

ENV PYTHONUNBUFFERED=1
ENV MODEL_CACHE_DIR=/models
ENV CHECKPOINT_DIR=/checkpoints

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "src.server:app", "--host", "0.0.0.0", "--port", "8000"]
