# Example Terraform variables configuration
# Copy this file to terraform.tfvars and update with your actual values

# Required: Docker images for services
billing_image       = "ghcr.io/one-covenant/basilica/basilica-billing:latest"
payments_image      = "ghcr.io/one-covenant/basilica/basilica-payments:latest"
basilica_api_image  = "ghcr.io/one-covenant/basilica/basilica-api:latest"

# Required: Basilica API Bittensor configuration
basilica_api_validator_hotkey = "5G3qVaXzKMPDm5AJ3dpzbpUC27kpccBvDwzSWXrq8M6qMmbC"

# Optional: AWS region (default: us-east-2)
aws_region = "us-east-2"

# Optional: Project name (default: basilica)
project_name = "basilica"

# Required: ACM certificate ARN for HTTPS/TLS
certificate_arn = "arn:aws:acm:us-east-2:ACCOUNT_ID:certificate/CERTIFICATE_ID"

# Optional: Bittensor network configuration
basilica_api_network = "finney"
basilica_api_netuid  = 39

# Optional: Auth0 configuration
basilica_auth0_domain   = "tenant.auth0.com"
basilica_auth0_client_id = "auth0-client-id"
basilica_auth0_audience  = "https://api.basilica.ai/"
basilica_auth0_issuer    = "https://tenant.auth0.com/"

# Validator IP Whitelisting for Billing gRPC Endpoint
# List of validator IP addresses/CIDR blocks allowed to access billing.basilica.ai
# Leave empty [] to allow all traffic (not recommended for production)
validator_allowed_ips = [
  "203.0.113.10/32",     # Validator 1
  "203.0.113.20/32",     # Validator 2
  "198.51.100.0/24",     # Validator subnet
]

# Route53 DNS Management (Optional)
# Leave empty "" if using external DNS provider
# You'll manually create CNAME record using terraform output billing_grpc_endpoint
route53_zone_id = ""

# Example with Route53 enabled:
# route53_zone_id = "Z1234567890ABC"
# This will create an A record: billing.basilica.ai -> Internal ALB

# Marketplace API Key (Required for dynamic pricing)
# Get your API key from Shadeform: https://shadeform.ai/
marketplace_api_key = "your-shadeform-api-key"

# Cold Wallet Address (Required for reconciliation)
# This is the SS58 address where swept funds will be sent
# Example: "5GrwvaEF5zXb26Fz9rcQpDWS57CtERHpNehXCPcNoHGKutQY"
payments_reconciliation_coldwallet_address = ""

# Enable Reconciliation Service
# Set to true to enable automatic hotwallet sweeps
# Recommended: Start with false, test in dry-run mode first
payments_reconciliation_enabled = false

# Dry Run Mode
# When true, the service logs what it would do without executing transfers
# Recommended: Keep true until thoroughly tested
payments_reconciliation_dry_run = true

# =============================================================================
# RECONCILIATION PARAMETERS (configured in compute.tf)
# =============================================================================
# These are set in compute.tf but can be overridden if needed:
#
# SWEEP_INTERVAL_SECONDS       = 300        # Check every 5 minutes
# MINIMUM_THRESHOLD_PLANCKS    = 1000000000 # 1 TAO (sweep when balance > this)
# TARGET_BALANCE_PLANCKS       = 550000000  # 0.55 TAO (leave this much)
# ESTIMATED_FEE_PLANCKS        = 50000000   # 0.05 TAO (estimated tx fee)
# MAX_RETRIES                  = 3          # Retry failed transfers 3 times
#
# Formula: sweep_amount = current_balance - (TARGET_BALANCE + ESTIMATED_FEE)
# Example: If balance is 2.0 TAO, sweep: 2.0 - (0.55 + 0.05) = 1.4 TAO

# =============================================================================
# K8S KUBECONFIG (Optional - for K8s deployments feature)
# =============================================================================
# Path to kubeconfig file for API to connect to K3s cluster
# Terraform will automatically upload this to AWS Secrets Manager
# The path supports ~ expansion (e.g., ~/.kube/k3s-basilica-config)
# Leave empty "" to manually upload kubeconfig via AWS CLI
kubeconfig_path = "~/.kube/k3s-basilica-config"

k3s_server_url   = ""
k3s_ssh_enabled  = "true"
k3s_ssh_servers  = ""
k3s_ssh_username = ""
k3s_ssh_key_path = ""

cloudflare_api_token     = "your-cloudflare-api-token"
cloudflare_zone_id       = "your-cloudflare-zone-id"
cloudflare_domain        = "deployments.basilica.ai"
deployments_alb_dns_name = "your-deployments-alb-dns-name"

# =============================================================================
# GPU AGGREGATOR CONFIGURATION (Secure Cloud)
# =============================================================================
# Hyperstack GPU provider configuration
# Get your API key from: https://infrahub-api.nexgencloud.com/

# API key for authentication
hyperstack_api_key = "your-hyperstack-api-key"

# Webhook secret for callback authentication (must be URL-safe: A-Z a-z 0-9 - _ . ~)
hyperstack_webhook_secret = "your-url-safe-webhook-secret"

# Base URL for webhooks (where Hyperstack will send callbacks)
hyperstack_callback_base_url = "https://api.basilica.ai"

# =============================================================================
# VPC PEERING CONFIGURATION (Required for K3s SSH connectivity)
# =============================================================================
# These values come from the orchestrator/cloud Terraform outputs
# Run: cd orchestrator/cloud && terraform output
# k3s_vpc_peering_connection_id is the VPC peering connection ID
# k3s_vpc_cidr is the CIDR block of the K3s VPC (e.g., 10.101.0.0/16)
k3s_vpc_peering_connection_id = ""
k3s_vpc_cidr                  = ""

# =============================================================================
# VIP (MANAGED MACHINES) CONFIGURATION
# =============================================================================
# VIP allows team-managed GPU machines to be synced from an S3 CSV file
# and made available to specific users through the rental system.

# S3 bucket containing VIP machines CSV file
# Example: "my-company-vip-machines"
vip_s3_bucket = ""

# S3 object key for the CSV file
# Example: "vip/machines.csv"
vip_s3_key = ""

# S3 region (optional - defaults to aws_region if not specified)
# Example: "us-east-2"
vip_s3_region = ""

# Polling interval in seconds (how often to sync from S3)
# Default: 60 seconds
vip_poll_interval_secs = 60

# =============================================================================
# VIP CSV FILE FORMAT
# =============================================================================
# The CSV file in S3 should have the following columns:
# vip_machine_id, assigned_user, active, ssh_host, ssh_port, ssh_user,
# gpu_type, gpu_count, region, hourly_rate, vcpu_count, system_memory_gb, notes
#
# Example CSV:
# vip_machine_id,assigned_user,active,ssh_host,ssh_port,ssh_user,gpu_type,gpu_count,region,hourly_rate,vcpu_count,system_memory_gb,notes
# machine-001,auth0|user123,1,10.0.0.1,22,ubuntu,H100,8,us-east-1,25.00,128,500,Production H100 cluster
# machine-002,auth0|user456,1,10.0.0.2,22,ubuntu,A100,4,us-west-2,12.00,64,256,
