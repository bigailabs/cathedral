# Basilica Validator Configuration - Example
# Copy this file to validator.toml and customize for your environment

# Bittensor Network Configuration
[bittensor]
# IMPORTANT: Replace with your actual wallet and hotkey names
wallet_name = "YOUR_VALIDATOR_WALLET"
hotkey_name = "YOUR_VALIDATOR_HOTKEY"
network = "finney"  # Use "local" for development
netuid = 39  # Basilica subnet ID
chain_endpoint = "wss://entrypoint-finney.opentensor.ai:443"

# API Server Configuration
[server]
host = "0.0.0.0"
port = 8080
max_connections = 500
request_timeout = 30
enable_cors = true

# Database Configuration  
[database]
url = "sqlite:/opt/basilica/data/validator.db"
max_connections = 20
run_migrations = true
backup_enabled = true
backup_interval = 86400  # 24 hours

# Logging Configuration
[logging]
level = "info"
format = "json"
enable_file_logging = true
log_dir = "/var/log/basilica"

# Metrics Configuration
[metrics]
enabled = true
port = 9090
collection_interval = 30

# Validation Configuration
[validation]
max_concurrent_validations = 10
validation_timeout = 120
challenge_timeout = 60
min_score_threshold = 0.1
verification_interval = 600  # 10 minutes
min_verification_interval = 1800  # 30 minutes

[verification.cpu_pow]
default_iterations = 500000
chunk_size = 4096
sample_count = 4
baseline_cores = 32
baseline_mhz = 2800
target_secs = 2
cpu_model_iterations = {
  "AMD EPYC 9654" = 800000,
  "AMD EPYC 7763" = 700000,
  "AMD EPYC 7713" = 700000,
  "AMD EPYC 7543" = 650000,
  "AMD EPYC 7B13" = 650000,
  "Intel(R) Xeon(R) Platinum 8480+" = 800000,
  "Intel(R) Xeon(R) Platinum 8468" = 750000,
  "Intel(R) Xeon(R) Gold 6348" = 600000,
  "Intel(R) Xeon(R) Gold 6338" = 550000,
  "Intel(R) Xeon(R) Silver 4314" = 350000
}

[verification.storage_pow]
data_dir = "/tmp/veritas_storage"
file_size_bytes = 268435456 # 256MB
block_size = 4096
sample_count = 4

[verification.bandwidth_pow]
bytes = 67108864 # 64MB
chunk_size = 1048576 # 1MB
mode = "download"
target_secs = 2
probe_bytes = 4194304 # 4MB

# Scoring Configuration
[scoring]
min_stake_threshold = 1000.0
max_miners_to_validate = 20
score_decay_factor = 0.95
weight_update_interval = 300  # 5 minutes

# SSH Validation Configuration
[ssh_validation]
max_concurrent_sessions = 5
session_timeout = 300  # 5 minutes
connection_timeout = 30
retry_attempts = 3
cleanup_temp_files = true

# IMPORTANT: Configure your SSH keys
[ssh_keys]
private_key_path = "/etc/basilica/keys/validator_ssh"
public_key_path = "/etc/basilica/keys/validator_ssh.pub"
key_type = "ed25519"

# Security Configuration
[security]
enable_tls = false  # Set to true for production
require_https = false  # Set to true for production
rate_limit_requests_per_minute = 1000
# IMPORTANT: Add your miner IPs
allowed_miners = [
    "YOUR_MINER_IP_HERE",
]

# API Authentication
[api_auth]
enable_authentication = true
jwt_secret = ""  # Will be auto-generated if empty
token_expiry = 3600  # 1 hour
require_signature_verification = true

# Performance Tuning
[performance]
worker_threads = 4
max_blocking_threads = 512
thread_stack_size = 2097152  # 2MB

# Health Check Configuration
[health_checks]
enabled = true
interval = 30
timeout = 10
max_failures = 3

# Backup Configuration
[backup]
enabled = true
retention_days = 30
backup_dir = "/var/backups/basilica"
compress_backups = true

# TLS Configuration (for production)
[tls]
enabled = false
cert_path = "/etc/basilica/certs/validator.crt"
key_path = "/etc/basilica/certs/validator.key"
ca_cert_path = "/etc/basilica/certs/ca.crt"