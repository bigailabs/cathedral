{
  "container_image": "nvidia/cuda:12.0-runtime",
  "command": ["nvidia-smi", "-l", "30"],
  "resources": {
    "cpu": "2",
    "memory": "8Gi",
    "gpus": {
      "count": 1,
      "model": ["RTX 3090"]
    }
  },
  "network": {
    "ingress_ports": [
      {
        "port": 8888,
        "protocol": "TCP"
      }
    ],
    "egress_policy": "open"
  }
}
