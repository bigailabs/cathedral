apiVersion: apps/v1
kind: Deployment
metadata:
  name: basilica-api
  namespace: basilica-system
  labels:
    app: basilica-api
spec:
  replicas: 1
  selector:
    matchLabels:
      app: basilica-api
  template:
    metadata:
      labels:
        app: basilica-api
    spec:
      serviceAccountName: basilica-api
      containers:
        - name: api
          image: {{ api_image | quote }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 8000
            - name: metrics
              containerPort: 9401
          env:
            - name: RUST_LOG
              value: info
            - name: BASILICA_API_RENTAL_BACKEND
              value: k8s
            - name: BASILICA_API_BITTENSOR__NETWORK
              value: test
            - name: BASILICA_API_BITTENSOR__NETUID
              value: "387"
            - name: BASILICA_API_BITTENSOR__CHAIN_ENDPOINT
              value: wss://test.finney.opentensor.ai:443
            - name: BASILICA_API_BITTENSOR__VALIDATOR_HOTKEY
              value: {{ api_hotkey | default('REPLACE_VALIDATOR_HOTKEY') | quote }}
            - name: BASILICA_API_DATABASE__URL
              value: {{ api_database_url | quote }}
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "1Gi"
---
apiVersion: v1
kind: Service
metadata:
  name: basilica-api
  namespace: basilica-system
  labels:
    app: basilica-api
spec:
  selector:
    app: basilica-api
  ports:
    - name: http
      port: 8000
      targetPort: 8000
    - name: metrics
      port: 9401
      targetPort: 9401

