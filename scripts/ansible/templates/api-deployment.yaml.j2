apiVersion: apps/v1
kind: Deployment
metadata:
  name: basilica-api
  namespace: basilica-system
  labels:
    app: basilica-api
spec:
  replicas: 1
  selector:
    matchLabels:
      app: basilica-api
  template:
    metadata:
      labels:
        app: basilica-api
    spec:
      initContainers:
        - name: install-subtensor-ca
          image: debian:bookworm-slim
          command: ["bash","-lc","set -euo pipefail; apt-get update >/dev/null 2>&1 && apt-get install -y ca-certificates >/dev/null 2>&1; mkdir -p /custom; cp /ca/tls.crt /custom/subtensor-ca.crt; cat /etc/ssl/certs/ca-certificates.crt /custom/subtensor-ca.crt > /work/ca-bundle.crt; chown 1000:1000 /work/ca-bundle.crt"]
          volumeMounts:
            - name: subtensor-ca
              mountPath: /ca
              readOnly: true
            - name: custom-ca-bundle
              mountPath: /work
      serviceAccountName: basilica-api
      containers:
        - name: api
          image: {{ (api_image_effective | default(api_image)) | quote }}
          imagePullPolicy: Always
          ports:
            - name: http
              containerPort: 8000
            - name: metrics
              containerPort: 9401
          env:
            - name: RUST_LOG
              value: "info"
            - name: BASILICA_API_RENTAL_BACKEND
              value: "k8s"
            - name: BASILICA_API_BITTENSOR__NETWORK
              value: "{{ api_bittensor_network | default('test') }}"
            - name: BASILICA_API_BITTENSOR__NETUID
              value: "{{ api_bittensor_netuid | default('387') }}"
            - name: BASILICA_API_BITTENSOR__CHAIN_ENDPOINT
              value: "{{ api_chain_endpoint | default('wss://test.finney.opentensor.ai:443') }}"
            - name: BASILICA_API_BITTENSOR__VALIDATOR_HOTKEY
              value: "{{ api_hotkey | default('REPLACE_VALIDATOR_HOTKEY') }}"
            - name: BASILICA_API_DATABASE__URL
              value: "{{ api_database_url }}"
            - name: SSL_CERT_FILE
              value: /etc/ssl/custom/ca-bundle.crt
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "1Gi"
          volumeMounts:
            - name: custom-ca-bundle
              mountPath: /etc/ssl/custom
              readOnly: true
      volumes:
        - name: subtensor-ca
          secret:
            secretName: {{ subtensor_wss.secret_name | default('subtensor-tls') }}
        - name: custom-ca-bundle
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: basilica-api
  namespace: basilica-system
  labels:
    app: basilica-api
spec:
  selector:
    app: basilica-api
  ports:
    - name: http
      port: 8000
      targetPort: 8000
    - name: metrics
      port: 9401
      targetPort: 9401
