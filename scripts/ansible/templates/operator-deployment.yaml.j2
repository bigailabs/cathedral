apiVersion: apps/v1
kind: Deployment
metadata:
  name: basilica-operator
  namespace: basilica-system
  labels:
    app: basilica-operator
spec:
  replicas: 1
  selector:
    matchLabels:
      app: basilica-operator
  template:
    metadata:
      labels:
        app: basilica-operator
    spec:
      serviceAccountName: basilica-operator
      tolerations:
        # Allow scheduling on control-plane nodes (for single-node clusters)
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule
      containers:
        - name: operator
          image: {{ (operator_image_effective | default(operator_image)) | quote }}
          imagePullPolicy: {{ operator_image_pull_policy | default('IfNotPresent') }}
          env:
            - name: RUST_LOG
              value: info
            - name: BASILICA_ENABLE_K8S_METRICS
              value: "true"
            - name: DEPLOYMENT_PUBLIC_IP
              value: "{{ deployment_public_ip | default('localhost') }}"
            - name: DEPLOYMENT_PUBLIC_PORT
              value: "{{ deployment_public_port | default('8080') }}"
          resources:
            requests:
              cpu: "100m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          ports:
            - name: metrics
              containerPort: 9400
---
apiVersion: v1
kind: Service
metadata:
  name: basilica-operator
  namespace: basilica-system
  labels:
    app: basilica-operator
spec:
  selector:
    app: basilica-operator
  ports:
    - name: metrics
      port: 9400
      targetPort: 9400
