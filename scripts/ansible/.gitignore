# Ansible Vault password file (NEVER COMMIT!)
.vault_password
*.vault_password

# Ansible retry files
*.retry

# Ansible facts cache
.ansible_facts/

# Ansible roles downloaded from Galaxy
roles/external/

# Production inventory files (keep example.ini)
inventories/production.ini
inventories/staging.ini
inventories/prod.ini
inventories/*.ini
!inventories/example.ini

# Vault files with secrets (keep .example files)
group_vars/all/vault.yml
group_vars/*/vault.yml
host_vars/*/vault.yml
**/vault.yml
!**/vault.yml.example

# Host-specific variables with production data
host_vars/

# Kubeconfig files
*.kubeconfig
*kubeconfig*
k3s.yaml
k3s-config.yaml
build/k3s.yaml
~/.kube/k3s-*

# SSH keys and certificates
*.pem
*.key
!*.key.example
*.pub
id_rsa*
id_ed25519*

# Cloud credentials
*credentials*
!*credentials*.example
*secret*
!*secret*.example
.env
.env.*
!.env.example

# R2/S3 credentials
r2-credentials.yml
group_vars/all/r2.yml
!group_vars/all/r2.yml.example

# Terraform state (if mixed with Ansible)
*.tfstate
*.tfstate.*
.terraform/

# Logs
*.log
logs/

# Temporary files
*.tmp
*.bak
*~
.DS_Store

# Python bytecode (if using Ansible with Python modules)
*.pyc
__pycache__/
.pytest_cache/

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Output directories
output/
downloads/
fetched/
